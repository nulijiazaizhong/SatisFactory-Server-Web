FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY backend/package*.json ./

# Install dependencies
RUN npm ci

# Copy backend source
COPY backend/src ./src
COPY backend/tsconfig.json ./

# Build TypeScript
RUN npm run build

# Copy config file (can be overridden via volume mount)
COPY backend/config.json ./

EXPOSE 3001

CMD ["npm", "start"]